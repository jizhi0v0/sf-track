# HTTP server
BIND_ADDR=0.0.0.0:3000
RUST_LOG=sf_track=info,tower_http=warn

# SF Express Open Platform
# 顺丰开放平台「顾客编码」填入 SF_PARTNER_ID
# 顺丰开放平台「校验码」填入 SF_CHECK_WORD
# sandbox: https://sfapi-sbox.sf-express.com/std/service
# production: https://sfapi.sf-express.com/std/service
SF_ENV=sandbox
SF_API_BASE_URL=https://sfapi-sbox.sf-express.com/std/service
SF_PARTNER_ID=replace-with-server-side-partner-id
SF_CHECK_WORD=replace-with-server-side-check-word

# Page access tokens.
# Format: token:expiresAt:maxUses
# expiresAt uses RFC3339 UTC time. Multiple tokens are comma-separated.
TRACKING_ACCESS_TOKENS=dev-token-change-me:2026-12-31T23:59:59Z:20

# Session cookie exchanged from URL token.
SESSION_TTL_SECONDS=1800
SESSION_COOKIE_SECURE=false
